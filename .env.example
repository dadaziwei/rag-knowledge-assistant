# ===== General Settings =====
COMPOSE_PROJECT_NAME=rag_knowledge_assistant
DEBUG_MODE=false
SERVER_IP=http://localhost:18080

# Optional Docker build proxy. Leave empty when not needed.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,backend,frontend,nginx,kafka,redis,mysql,mongodb,minio,milvus-standalone,milvus-etcd,milvus-minio,unoserver

# ===== Database Credentials =====
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=daziknow
MYSQL_USER=daziknow
MYSQL_PASSWORD=change-me-mysql-password

REDIS_PASSWORD=change-me-redis-password
REDIS_TOKEN_DB=0
REDIS_TASK_DB=1
REDIS_LOCK_DB=2

MONGODB_ROOT_USERNAME=daziknow
MONGODB_ROOT_PASSWORD=change-me-mongodb-password
MONGODB_DB=daziknow

MINIO_ACCESS_KEY=daziknow
MINIO_SECRET_KEY=change-me-minio-secret
MILVUS_MINIO_ACCESS_KEY=change-me-milvus-minio-access-key
MILVUS_MINIO_SECRET_KEY=change-me-milvus-minio-secret-key

# ===== Frontend Configuration =====
NEXT_PUBLIC_API_BASE_URL=/api/v1
MINIO_IMAGE_URL_PREFIX=/minio
NODE_ENV=production

# ===== Backend Service Configuration =====
DB_URL=mysql+pymysql://daziknow:change-me-mysql-password@mysql:3306/daziknow
REDIS_URL=redis://:change-me-redis-password@redis:6379
MONGODB_URL=mongodb://daziknow:change-me-mongodb-password@mongodb:27017

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=43200

MAX_WORKERS=4
LOG_LEVEL=INFO
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
MONGODB_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

KAFKA_BROKER_URL=kafka:9092
KAFKA_TOPIC=rag-file-processing
KAFKA_GROUP_ID=rag-file-consumer
KAFKA_PARTITIONS_NUMBER=10
KAFKA_REPLICATION_FACTOR=1
KAFKA_ENABLED=true

MINIO_URL=http://minio:9000
MINIO_BUCKET_NAME=daziknow

MILVUS_URI=http://milvus-standalone:19530
COLBERT_MODEL_PATH=/model_weights/colbert

SANDBOX_SHARED_VOLUME=/shared

UNOSERVER_INSTANCES=1
UNOSERVER_HOST=unoserver
UNOSERVER_BASE_PORT=2003
UNOSERVER_BASE_UNO_PORT=2002
WAIT_FOR_UNOSERVER=true

EMBEDDING_IMAGE_DPI=100
EMBEDDING_MODEL=jina-embeddings-v4
EMBEDDING_FALLBACK_ENABLED=true
JINA_API_KEY=replace-with-your-jina-api-key
JINA_EMBEDDINGS_V4_URL=https://api.jina.ai/v1/embeddings

DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

MODEL_BASE_URL=https://hf-mirror.com
